ZUEB_USERNAME=你的工号
ZUEB_PASSWORD=你的密码

# 可选：默认打卡坐标，格式为“经度,纬度”
ZUEB_ATTENDANCE_DEFAULT_XY=113.719755,34.615436

TELEGRAM_BOT_TOKEN=你的TelegramBotToken
ANTHROPIC_API_KEY=你的AnthropicApiKey
# 可选：第三方 Claude API 网关地址（不填则使用官方默认）
ANTHROPIC_BASE_URL=
# 可选：Claude 模型名（例如 claude-sonnet-4-5）
ANTHROPIC_MODEL=
# 可选：日志级别（DEBUG/INFO/WARNING/ERROR/CRITICAL）
BOT_LOG_LEVEL=INFO
OWNER_ID=你的Telegram数字ID

# 每晚自动检查打卡并推送到 Telegram（可选）
NIGHTLY_CHECK_ENABLED=true
NIGHTLY_CHECK_TIME=21:30
NIGHTLY_CHECK_TIMEZONE=Asia/Shanghai
NIGHTLY_CHECK_RETRIES=2
NIGHTLY_CHECK_PROMPT=查看是否打卡

# 工作日自动打卡安全网（可选）
AUTO_PUNCH_ENABLED=false
AUTO_PUNCH_TIMEZONE=Asia/Shanghai
AUTO_PUNCH_MORNING_NOTIFY=07:52
AUTO_PUNCH_MORNING_PUNCH=07:55
AUTO_PUNCH_EVENING_NOTIFY=17:57
AUTO_PUNCH_EVENING_PUNCH=18:00
AUTO_PUNCH_RETRIES=1
